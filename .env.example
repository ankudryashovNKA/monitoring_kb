# Supabase PostgreSQL connection settings
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xxxxxxxx
SUPABASE_DB_PASSWORD=your_password_here

# Hippocrates Knowledge Base integration
KB_ID=your_kb_id
KB_JWT_TOKEN=your_jwt_token
# Optional overrides:
# KB_API_BASE_URL=https://kb.ai-hippocrates.ru/kbapi
# KB_PRESET_NAME=Monitoring server

# Dashboard auth
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me
# Optional signature secret for auth cookie
# AUTH_SECRET=change-me-in-production
# Optional SMTP settings for trigger email alerts
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=app_password
# SMTP_SENDER=monitoring@example.com
# SMTP_USE_TLS=true

# Agent runtime configuration
SERVER_URL=http://127.0.0.1:8000
AGENT_ID=copy_from_register_new_node
AGENT_SECRET=copy_from_register_new_node
# Optional: NODE_ID override (defaults to hostname)
# NODE_ID=node-1
